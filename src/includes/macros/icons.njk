{% macro close(size=24, strokeWidth=2, class="", ariaHidden="true") %}
<svg width="{{ size }}" height="{{ size }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="{{ strokeWidth }}" stroke-linecap="round" stroke-linejoin="round"{% if class %} class="{{ class }}"{% endif %} aria-hidden="{{ ariaHidden }}">
    <line x1="18" y1="6" x2="6" y2="18"></line>
    <line x1="6" y1="6" x2="18" y2="18"></line>
</svg>
{% endmacro %}

{% macro chevron(direction="left", size=24, strokeWidth=2, class="", ariaHidden="true") %}
<svg width="{{ size }}" height="{{ size }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="{{ strokeWidth }}" stroke-linecap="round" stroke-linejoin="round"{% if class %} class="{{ class }}"{% endif %} aria-hidden="{{ ariaHidden }}">
    {% if direction == "left" %}
    <polyline points="15 18 9 12 15 6"></polyline>
    {% else %}
    <polyline points="9 18 15 12 9 6"></polyline>
    {% endif %}
</svg>
{% endmacro %}

