{% from "macros/icons.njk" import sun, moon %}
<header class="header">
    <div class="container">
        <a href="/" class="header__logo">
            <!--<span class="header__logo-icon">🐱</span>-->
            <img class="header__logo-icon" src="/assets/logos/logo.svg" alt="" width="32" height="32">
            <span class="header__logo-text">{{ data.pet.name }}</span>
        </a>
        <nav class="header__nav" id="main-nav">
            <ul class="header__nav-list">
                <li><a href="#about" class="header__nav-link">About</a></li>
                {% if data.pet.hasData %}
                <li><a href="#gallery" class="header__nav-link">Gallery</a></li>
                {% endif %}
                {% if data.health.hasData %}
                <li><a href="#health" class="header__nav-link">Health</a></li>
                {% endif %}
                {% if data.owner.hasData %}
                <li><a href="#contact" class="header__nav-link">Contact</a></li>
                {% endif %}
            </ul>
        </nav>
        <div class="header__actions">
            <button class="theme-toggle" id="theme-toggle" aria-label="Toggle dark mode" title="Toggle dark mode">
                {{ sun(24, 2, "theme-toggle__icon theme-toggle__icon--light") }}
                {{ moon(24, 2, "theme-toggle__icon theme-toggle__icon--dark") }}
            </button>
            <button class="header__menu-toggle" aria-label="Toggle menu" aria-expanded="false" id="menu-toggle">
                <span class="header__menu-icon"></span>
            </button>
        </div>
    </div>
</header>
