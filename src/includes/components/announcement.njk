{% from "macros/icons.njk" import close %}
{% if data.site.announcement and data.site.announcement.enabled and data.site.announcement.message %}
{% set colour = data.site.announcement.colour | default("neutral") %}
<div class="announcement announcement--{{ colour }}" id="announcement" data-announcement-id="{{ data.site.announcement.message | sha1 }}" aria-live="polite">
    <div class="announcement__inner container">
        <p class="announcement__message">{{ data.site.announcement.message | markdownInline | safe }}</p>
        <button class="announcement__close" aria-label="Dismiss announcement">
            {{ close(16, 2.5) }}
        </button>
    </div>
</div>
{% endif %}
